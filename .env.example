# Discord bot token (required)
DISCORD_TOKEN=

# Proxmox VE API connection (required)
# If behind Cloudflare Tunnel / reverse proxy, omit the port
PROXMOX_URL=https://pve1:8006
PROXMOX_TOKEN_ID=root@pam!discord-bot
PROXMOX_TOKEN_SECRET=

# Optional: Dev guild ID for instant command registration (recommended during development)
# DEV_GUILD_ID=

# Optional: Channel to receive health alerts
# ALERT_CHANNEL_ID=

# Optional: Health check interval (seconds, default: 60)
# MONITOR_INTERVAL_SECS=60

# Optional: Accept self-signed TLS certificates (default: true)
# ACCEPT_INVALID_CERTS=true
