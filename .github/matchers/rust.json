{
  "problemMatcher": [
    {
      "owner": "rust",
      "pattern": [
        {
          "regexp": "^(?:error|warning)\\[(\\w+)\\]: (.+)$",
          "severity": 1,
          "message": 2
        }
      ]
    },
    {
      "owner": "clippy",
      "pattern": [
        {
          "regexp": "^(.+):(\\d+):(\\d+): (\\w+): (.+)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        }
      ]
    }
  ]
}
